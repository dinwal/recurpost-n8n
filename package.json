{
  "name": "n8n-nodes-recurpost",
  "version": "1.1.7",
  "description": "N8N community node for RecurPost - Schedule and automate your social media posts",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "recurpost",
    "social-media",
    "scheduling",
    "automation"
  ],
  "license": "MIT",
  "homepage": "https://recurpost.com",
  "author": {
    "name": "RecurPost",
    "email": "support@recurpost.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dinwal/recurpost-n8n.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/RecurPostApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/RecurPost/RecurPost.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.56.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.20.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
