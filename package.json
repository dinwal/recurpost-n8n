{
  "name": "n8n-nodes-recurpost",
  "version": "1.2.0",
  "description": "N8N community node for RecurPost - Schedule and automate your social media posts",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "recurpost",
    "social-media",
    "scheduling",
    "automation"
  ],
  "license": "MIT",
  "homepage": "https://recurpost.com",
  "author": {
    "name": "RecurPost",
    "email": "support@recurpost.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dinwal/recurpost-n8n.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "n8n-node build",
    "postbuild": "node scripts/copy-codex.mjs",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/RecurPostApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/RecurPost/RecurPost.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "latest",
    "eslint": "9.29.0",
    "n8n-workflow": "^1.20.0",
    "prettier": "3.8.3",
    "release-it": "20.2.0",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
